.navbar
  h1 🧟 Escape the Outbreak

  .navbar-items
    .profile-container
      img.profile-icon(src="/images/profile.png", alt="Profile")

      .profile-dropdown
        if user
          p= user.username
          hr
          a(href="/lobby") Lobby
          a(href="/auth/logout") Logout
        else
          a(href="/login") Login
          a(href="/register") Sign Up